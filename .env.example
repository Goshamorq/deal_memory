# GigaChat API credentials
# Get from https://developers.sber.ru/portal/products/gigachat-api
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Model name (GigaChat / GigaChat-Pro / GigaChat-Max)
GIGACHAT_MODEL=GigaChat

# Set to "true" to skip SSL verification (for environments without Russian Trusted Root CA installed).
# Educational project — acceptable; do NOT use in production.
GIGACHAT_VERIFY_SSL=false
